{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A daily task or work item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "subject": { "type": "string" },
              "work": { "type": "string" }
            }
          }
        },
        "date": { "type": "string", "format": "date" },
        "completed": { "type": "boolean" },
        "category": { "type": "string", "enum": ["work", "personal", "other"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "workTypes": { "type": "array", "items": { "type": "string" } },
        "dueDate": { "type": "string", "format": "date" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "date", "completed", "userId", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (income, expense, or savings)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense", "savings"] },
        "amount": { "type": "number" },
        "category": { "type": "string", "enum": ["work", "personal"] },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "subCategory": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["cash", "factory_money", "own_money"] },
        "milkQuantity": { "type": "number" },
        "fuelLiters": { "type": "number" },
        "fuelPricePerLiter": { "type": "number" },
        "fuelType": { "type": "string" },
        "workLocation": { "type": "string" },
        "shopName": { "type": "string" },
        "itemsBought": { "type": "string" },
        "maintenanceType": { "type": "string" },
        "receiptItems": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" }
            }
          }
        },
        "driverName": { "type": "string" },
        "customerName": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "receiptImage": { "type": "string" },
        "isDelivery": { "type": "boolean" },
        "discount": { "type": "number" },
        "paidAmount": { "type": "number" },
        "remainingAmount": { "type": "number" },
        "debtAmount": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "amount", "category", "description", "date", "userId", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "User preferences and history",
      "type": "object",
      "properties": {
        "descriptions": { "type": "array", "items": { "type": "string" } },
        "history": { "type": "object" },
        "customTabs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "MaintenanceInvoice": {
      "title": "MaintenanceInvoice",
      "description": "A maintenance invoice",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "invoiceNumber": { "type": "string" },
        "date": { "type": "string" },
        "customerName": { "type": "string" },
        "mobile": { "type": "string" },
        "deviceInfo": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "discount": { "type": "number" },
        "totalAfterDiscount": { "type": "number" },
        "cashPaid": { "type": "number" },
        "debtAmount": { "type": "number" },
        "remainingBalance": { "type": "number" },
        "technicianName": { "type": "string" },
        "warranty": { "type": "string" },
        "notes": { "type": "string" },
        "receivedFromFactory": { "type": "number" },
        "factoryOwesMe": { "type": "number" },
        "iOweFactory": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "invoiceNumber", "date", "customerName", "createdAt"]
    },
    "Activity": {
      "title": "Activity",
      "description": "A user activity log entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "title": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "entityType": { "type": "string", "enum": ["transaction", "task", "wishlist", "debt", "invoice", "system"] },
        "userId": { "type": "string" }
      },
      "required": ["id", "type", "title", "timestamp", "entityType"]
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "description": "An item the user wants to buy",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "estimatedPrice": { "type": "number" },
        "notes": { "type": "string" },
        "type": { "type": "string", "enum": ["general", "private"] },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "completed", "userId", "createdAt"]
    },
    "Debt": {
      "title": "Debt",
      "description": "A debt record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "personName": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["owed", "owing"] },
        "date": { "type": "string" },
        "notes": { "type": "string" },
        "completed": { "type": "boolean" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "personName", "amount", "type", "date", "userId", "createdAt"]
    },
    "SavingsGoal": {
      "title": "SavingsGoal",
      "description": "A financial savings goal",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "title", "targetAmount", "currentAmount", "userId", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A scanned product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "barcode": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "barcode", "name", "price", "userId", "createdAt"]
    },
    "Budget": {
      "title": "Budget",
      "description": "A monthly budget for a category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "category", "amount", "userId"]
    },
    "AppNotification": {
      "title": "AppNotification",
      "description": "An application notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "type": { "type": "string", "enum": ["reminder", "system", "alert", "expense_reminder"] },
        "userId": { "type": "string" }
      },
      "required": ["id", "title", "message", "timestamp", "read", "type", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "User's tasks"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User's transactions"
    },
    "/users/{userId}/settings/main": {
      "schema": "Settings",
      "description": "User's settings"
    },
    "/users/{userId}/maintenanceInvoices/{invoiceId}": {
      "schema": "MaintenanceInvoice",
      "description": "User's maintenance invoices"
    },
    "/users/{userId}/activities/{activityId}": {
      "schema": "Activity",
      "description": "User's activity log"
    },
    "/users/{userId}/wishlist/{wishlistItemId}": {
      "schema": "WishlistItem",
      "description": "User's wishlist items"
    },
    "/users/{userId}/debts/{debtId}": {
      "schema": "Debt",
      "description": "User's debts"
    },
    "/users/{userId}/savingsGoals/{goalId}": {
      "schema": "SavingsGoal",
      "description": "User's savings goals"
    },
    "/users/{userId}/products/{productId}": {
      "schema": "Product",
      "description": "User's scanned products"
    },
    "/users/{userId}/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "User's monthly budgets"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "AppNotification",
      "description": "User's notifications"
    }
  }
}
